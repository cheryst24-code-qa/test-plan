{
  "ignorePatterns": [
    {
      "pattern": "^#"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "^tel:"
    },
    {
      "pattern": "TODO"
    },
    {
      "pattern": "\\[.*\\]\\(.*\\)\\s*<!-- ignore-link -->"
    }
  ],
  "aliveStatusCodes": [
    200,
    403,
    429
  ],
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s"
}